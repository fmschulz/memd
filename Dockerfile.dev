# Development container with glibc 2.39 for ort-sys compatibility
FROM ubuntu:24.04

# Install Rust and build dependencies
RUN apt-get update && apt-get install -y \
    curl \
    build-essential \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Set working directory
WORKDIR /workspace

# Pre-download common dependencies (optional, for faster rebuilds)
# COPY Cargo.toml Cargo.lock ./
# RUN cargo fetch

CMD ["/bin/bash"]
